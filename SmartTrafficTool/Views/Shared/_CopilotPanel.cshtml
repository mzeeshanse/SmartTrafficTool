<div id="copilot-shell"
     class="copilot-shell"
     data-api-url="@Url.Content("~/api/Copilot/message")"
     data-speech-lang="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" ? "ar-QA" : "en-QA")">
    <button type="button"
            id="copilot-fab"
            class="copilot-fab btn btn-accent"
            aria-expanded="false"
            aria-controls="copilot-panel"
            title="@L["Copilot_OpenTooltip"]">
        <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
        <span class="copilot-fab-label">@L["Copilot_FabLabel"]</span>
    </button>

    <div id="copilot-panel"
         class="copilot-panel glass"
         role="dialog"
         aria-modal="true"
         aria-labelledby="copilot-panel-title"
         hidden>
        <div class="copilot-panel-header">
            <div>
                <div id="copilot-panel-title" class="copilot-panel-title">@L["Copilot_PanelTitle"]</div>
                <div class="copilot-panel-subtitle">@L["Copilot_PanelSubtitle"]</div>
            </div>
            <button type="button" class="btn btn-ghost btn-sm copilot-close" aria-label="@L["Copilot_CloseAria"]">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div id="copilot-messages" class="copilot-messages"></div>

        <div class="copilot-quick-picks" role="toolbar" aria-label="@L["Copilot_QuickAria"]">
            <span class="copilot-quick-picks-label">@L["Copilot_QuickLabel"]</span>
            <button type="button" class="copilot-quick-pick" data-copilot-message="Summary for 7 days">@L["Copilot_Msg_Summary7"]</button>
            <button type="button" class="copilot-quick-pick" data-copilot-message="Summary for Saudi Plate for 7 days">@L["Copilot_Msg_SummarySaudi"]</button>
            <button type="button" class="copilot-quick-pick" data-copilot-message="Summary for All Taxi 7 days">@L["Copilot_Msg_SummaryTaxi"]</button>
            <button type="button" class="copilot-quick-pick" data-copilot-message="Open Device 57">@L["Copilot_Msg_OpenDevice57"]</button>
            <button type="button" class="copilot-quick-pick" data-copilot-message="Open All Devices">@L["Copilot_Msg_OpenAllDevices"]</button>
            <button type="button" class="copilot-quick-pick" data-copilot-message="Summary of Plate with text ***" title="@L["Copilot_Msg_PlatePlaceholderHint"]">@L["Copilot_Msg_SummaryPlateTemplate"]</button>
            <button type="button" class="copilot-quick-pick" data-copilot-message="Investigate plate number 668928">@L["Copilot_Msg_DemoPlateInvestigate"]</button>
        </div>

        <div class="copilot-panel-footer">
            <div id="copilot-status" class="copilot-status" aria-live="polite"></div>
            <div class="copilot-input-row">
                <textarea id="copilot-input"
                          class="form-control copilot-input"
                          rows="2"
                          placeholder="@L["Copilot_InputPlaceholder"]"
                          autocomplete="off"></textarea>
                <div class="copilot-input-actions">
                    <button type="button" id="copilot-mic" class="btn btn-outline-light btn-sm" title="@L["Copilot_VoiceInputTitle"]">
                        <i class="fa-solid fa-microphone"></i>
                    </button>
                    <button type="button" id="copilot-send" class="btn btn-accent btn-sm">
                        <i class="fa-solid fa-paper-plane me-1"></i>@L["Copilot_Send"]
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div id="copilot-backdrop" class="copilot-backdrop" hidden></div>
</div>
