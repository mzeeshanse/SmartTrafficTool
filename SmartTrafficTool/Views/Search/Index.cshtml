            </div>
            <div class="card investigation-intel-card investigation-intel-card--flush-map">
                <div class="investigation-intel-accent investigation-intel-accent--live" aria-hidden="true"></div>
                <div class="investigation-intel-head">
                    <div class="investigation-intel-icon investigation-intel-icon--live" aria-hidden="true"><i class="fa-solid fa-location-crosshairs"></i></div>
                    <div class="investigation-intel-head-text">
