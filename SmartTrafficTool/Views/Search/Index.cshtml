    @if (Model.IsInvestigationMode)
    {
        var coTravelIsDemo = Model.CoTravelPlates.Count == 0;
        var coTravelDisplayList = coTravelIsDemo
            ? new List<string>
            {
                "45231 S · 2 reads · ~4 min overlap",
