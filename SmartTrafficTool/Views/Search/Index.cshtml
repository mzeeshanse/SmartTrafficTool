        }

        function escapeHtml(value) {
            return String(value)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#39;");
        }

        function bindPopupInteractions() {
            const popup = document.querySelector(".map-popup-card");
            if (!popup) {
                return;
            }

            const prevBtn = popup.querySelector(".map-popup-nav-prev");
            const nextBtn = popup.querySelector(".map-popup-nav-next");
            if (prevBtn && nextBtn && mapPopupAnchorMarker && mapPopupAnchorMarker.__popupRecords?.length > 1) {
                prevBtn.addEventListener("click", (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    const m = mapPopupAnchorMarker;
                    const n = m.__popupRecords.length;
                    m.__popupIndex = ((m.__popupIndex ?? 0) + n - 1) % n;
                    openSearchMarkerPopup(m);
                });
                nextBtn.addEventListener("click", (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    const m = mapPopupAnchorMarker;
                    const n = m.__popupRecords.length;
                    m.__popupIndex = ((m.__popupIndex ?? 0) + 1) % n;
                    openSearchMarkerPopup(m);
                });
            }

            const liveTrackingBtn = popup.querySelector(".popup-live-track-btn");
            if (liveTrackingBtn) {
                liveTrackingBtn.addEventListener("click", () => {
                    const lat = Number.parseFloat(popup.getAttribute("data-lat") || "");
                    const lng = Number.parseFloat(popup.getAttribute("data-lng") || "");
                    if (Number.isFinite(lat) && Number.isFinite(lng)) {
                        updateLiveTracking(lat, lng);
                    }
                });
            }

            const centerMapBtn = popup.querySelector(".popup-center-map-btn");
            if (centerMapBtn && searchMap) {
                centerMapBtn.addEventListener("click", (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    const lat = Number.parseFloat(popup.getAttribute("data-lat") || "");
                    const lng = Number.parseFloat(popup.getAttribute("data-lng") || "");
                    if (Number.isFinite(lat) && Number.isFinite(lng)) {
                        searchMap.panTo({ lat, lng });
                        const z = searchMap.getZoom();
                        if (!Number.isFinite(z) || z < 15) {
                            searchMap.setZoom(15);
                        }
                    }
                });
            }

            popup.addEventListener("wheel", (event) => {
                if (!event.ctrlKey || !searchMap) {
                    return;
                }

                event.preventDefault();
                event.stopPropagation();

                const currentZoom = searchMap.getZoom() || 10;
                const delta = event.deltaY < 0 ? 1 : -1;
                searchMap.setZoom(Math.max(3, Math.min(22, currentZoom + delta)));
            }, { passive: false });
        }

        function buildTrackingPath(points) {
            if (!points || points.length < 2) {
                return;
            }

            const sorted = points
                .filter(p => p.time instanceof Date && !isNaN(p.time.valueOf()))
                .sort((a, b) => a.time - b.time);

            if (sorted.length < 2) {
                return;
            }

            const path = sorted.map(p => ({
                lat: p.lat,
                lng: p.lng,
                time: p.time
            }));
            if (trackingPath) {
                trackingPath.setMap(null);
            }

            trackingPath = new google.maps.Polyline({
                path: [path[0]],
                geodesic: true,
                strokeColor: "#e8b4c2",
                strokeOpacity: 0.85,
                strokeWeight: 3
            });
            trackingPath.setMap(searchMap);

            currentSegmentPath = new google.maps.Polyline({
                path: [path[0]],
                geodesic: true,
                strokeColor: "#eb5757",
                strokeOpacity: 0.95,
                strokeWeight: 4
            });
            currentSegmentPath.setMap(searchMap);

            if (trackingStartMarker) {
                trackingStartMarker.setMap(null);
            }

            if (trackingEndMarker) {
                trackingEndMarker.setMap(null);
            }

            trackingStartMarker = new google.maps.Marker({
                map: searchMap,
                position: path[0],
                title: "Journey Start",
                icon: getJourneyPointIcon("#eb5757", "#ffffff", formatTrackingTime(path[0].time), "Start"),
                zIndex: 3000
            });

            trackingEndMarker = new google.maps.Marker({
                map: searchMap,
                position: path[path.length - 1],
                title: "Journey End",
                icon: getJourneyPointIcon("#27ae60", "#ffffff", formatTrackingTime(path[path.length - 1].time), "End"),
                zIndex: 3000
            });

            trackingTimeBadgeMarkers.forEach(marker => marker.setMap(null));
            trackingTimeBadgeMarkers = path
                .slice(1, -1)
                .map((point, index) => new google.maps.Marker({
                    map: null,
                    position: point,
                    title: `Record Time ${index + 1}`,
                    icon: getRecordTimeBadgeIcon(formatTrackingTime(point.time)),
                    zIndex: 2500
                }));

            const bounds = new google.maps.LatLngBounds();
            path.forEach(p => bounds.extend(p));
            searchMap.fitBounds(bounds);

            syncTrackingTimeBadgeVisibility();
            google.maps.event.addListenerOnce(searchMap, "idle", syncTrackingTimeBadgeVisibility);

            startTrackerAnimation(path);
        }

        function startTrackerAnimation(path) {
            if (!path || path.length < 2) {
                return;
            }
            trackerIndex = 0;
            if (!trackerMarker) {
                trackerMarker = new google.maps.Marker({
                    map: searchMap,
                    position: path[0],
                    icon: getVehicleIcon(0),
                    zIndex: 1500
                });
            } else {
                trackerMarker.setPosition(path[0]);
                trackerMarker.setIcon(getVehicleIcon(0));
                trackerMarker.setMap(searchMap);
                trackerMarker.setZIndex(1500);
            }

            cancelAnimationFrame(trackerTimer);
            animateTrackingSegment(path, 1);
        }

        function animateTrackingSegment(path, segmentIndex) {
            if (!isTracking) {
                return;
            }

            if (segmentIndex >= path.length) {
                if (currentSegmentDurationMarker) {
                    currentSegmentDurationMarker.setMap(null);
                    currentSegmentDurationMarker = null;
                }
                stopTracking();
                return;
            }

            const start = path[segmentIndex - 1];
            const end = path[segmentIndex];
            const segmentDurationMs = 1000;
            const segmentStartTime = performance.now();

            const drawFrame = (now) => {
                if (!isTracking) {
                    return;
                }

                const progress = Math.min((now - segmentStartTime) / segmentDurationMs, 1);
                const interpolated = interpolatePoint(start, end, progress);

                trackerMarker.setPosition(interpolated);
                trackerMarker.setIcon(getVehicleIcon(segmentIndex));

                const completedPath = path
                    .slice(0, segmentIndex)
                    .map(point => new google.maps.LatLng(point.lat, point.lng));
                completedPath.push(new google.maps.LatLng(interpolated.lat, interpolated.lng));
                trackingPath.setPath(completedPath);

                currentSegmentPath.setPath([
                    new google.maps.LatLng(start.lat, start.lng),
                    new google.maps.LatLng(interpolated.lat, interpolated.lng)
                ]);

                if (progress < 1) {
                    trackerTimer = requestAnimationFrame(drawFrame);
                    return;
                }

                trackerIndex = segmentIndex;
                animateTrackingSegment(path, segmentIndex + 1);
            };

            trackerTimer = requestAnimationFrame(drawFrame);
        }

        function getVehicleIcon(index) {
            const svg = `
                <svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 42 42">
                    <defs>
                        <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                            <feGaussianBlur stdDeviation="2" result="blur"/>
                            <feMerge>
                                <feMergeNode in="blur"/>
                                <feMergeNode in="SourceGraphic"/>
                            </feMerge>
                        </filter>
                    </defs>
                    <path d="M8 25l3-8 5-6h10l5 6 3 8v6h-3a3 3 0 0 1-6 0H17a3 3 0 0 1-6 0H8z"
                          fill="#c55272" stroke="#ffffff" stroke-width="1.5" filter="url(#glow)"/>
                    <rect x="15" y="14" width="12" height="6" rx="2" fill="#1a2a3d"/>
                    <circle cx="14" cy="30" r="2.4" fill="#0b1424"/>
                    <circle cx="28" cy="30" r="2.4" fill="#0b1424"/>
                    <circle cx="12" cy="22" r="2" fill="#5b84a2"/>
                    <circle cx="30" cy="22" r="2" fill="#5b84a2"/>
                </svg>`;

            return {
                url: "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg),
                scaledSize: new google.maps.Size(42, 42),
                anchor: new google.maps.Point(21, 21)
            };
        }

        function getJourneyPointIcon(fillColor, strokeColor, timeLabel, caption) {
            const svg = `
                <svg xmlns="http://www.w3.org/2000/svg" width="120" height="84" viewBox="0 0 120 84" fill="none">
                    <defs>
                        <filter id="journeyGlow" x="-50%" y="-50%" width="200%" height="200%">
                            <feGaussianBlur stdDeviation="2" result="blur"/>
                            <feMerge>
                                <feMergeNode in="blur"/>
                                <feMergeNode in="SourceGraphic"/>
                            </feMerge>
                        </filter>
                    </defs>
                    <rect x="10" y="4" width="100" height="28" rx="10" fill="rgba(11,20,36,0.92)" stroke="${strokeColor}" stroke-width="1.4"/>
                    <text x="60" y="16" text-anchor="middle" fill="#8fa1bd" font-size="10" font-family="Arial, sans-serif">${caption}</text>
                    <text x="60" y="26" text-anchor="middle" fill="#ffffff" font-size="12" font-weight="700" font-family="Arial, sans-serif">${timeLabel}</text>
                    <path d="M60 38C53.373 38 48 43.373 48 50c0 9.199 12 25 12 25s12-15.801 12-25C72 43.373 66.627 38 60 38z"
                          fill="${fillColor}" stroke="${strokeColor}" stroke-width="2" filter="url(#journeyGlow)"/>
                    <circle cx="60" cy="50" r="4.5" fill="#0b1424" stroke="${strokeColor}" stroke-width="1.2"/>
                </svg>`;

            return {
                url: "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg),
                scaledSize: new google.maps.Size(120, 84),
                anchor: new google.maps.Point(60, 76)
            };
        }

        function getRecordTimeBadgeIcon(timeLabel) {
            const svg = `
                <svg xmlns="http://www.w3.org/2000/svg" width="130" height="44" viewBox="0 0 130 44" fill="none">
                    <rect x="3" y="3" width="124" height="38" rx="12" fill="rgba(11,20,36,0.94)" stroke="#5b84a2" stroke-width="1.6"/>
                    <text x="65" y="17" text-anchor="middle" fill="#8fa1bd" font-size="10" font-family="Arial, sans-serif">Record Time</text>
                    <text x="65" y="29" text-anchor="middle" fill="#ffffff" font-size="12" font-weight="700" font-family="Arial, sans-serif">${timeLabel}</text>
                </svg>`;

            return {
                url: "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg),
                scaledSize: new google.maps.Size(130, 44),
                anchor: new google.maps.Point(65, 22)
            };
        }

        function formatTrackingTime(value) {
            if (!(value instanceof Date) || Number.isNaN(value.valueOf())) {
                return "--:--";
            }

            return value.toLocaleTimeString([], {
                hour: "2-digit",
                minute: "2-digit"
            });
        }

        function interpolatePoint(start, end, progress) {
            return {
                lat: start.lat + ((end.lat - start.lat) * progress),
                lng: start.lng + ((end.lng - start.lng) * progress)
            };
        }

        function initTrackingControl() {
            if (!searchMap || !window.google?.maps?.ControlPosition) {
                return;
            }
            if (!searchAllowsPlateTracking) {
                return;
            }

            const wrapper = document.createElement("div");
            wrapper.className = "map-control-widget";

            const toggleButton = document.createElement("button");
            toggleButton.id = "trackingToggleBtn";
            toggleButton.type = "button";
            toggleButton.className = "btn btn-ghost map-widget-btn";
            toggleButton.textContent = isTracking ? "Stop Tracking" : "Start Tracking";
            toggleButton.addEventListener("click", () => {
                if (isTracking) {
                    stopTracking();
                } else {
                    startTracking();
                }
            });

            const clearButton = document.createElement("button");
            clearButton.id = "trackingClearBtn";
            clearButton.type = "button";
            clearButton.className = "btn btn-ghost map-widget-btn";
            clearButton.textContent = "Clear Tracking";
            clearButton.addEventListener("click", () => {
                clearTrackingOverlay();
            });

            wrapper.appendChild(toggleButton);
            wrapper.appendChild(clearButton);
            searchMap.controls[google.maps.ControlPosition.TOP_RIGHT].push(wrapper);
            trackingToggleControl = toggleButton;
        }

        function setTrackingToggleLabel() {
            const btn = trackingToggleControl || document.getElementById("trackingToggleBtn");
            if (btn) {
                btn.textContent = isTracking ? "Stop Tracking" : "Start Tracking";
            }
        }

        function startTracking() {
            if (!searchAllowsPlateTracking) {
                return;
            }
            if (isTracking) {
                return;
            }
            clearTrackingOverlay(false);
            isTracking = true;
            setTrackingToggleLabel();
            buildTrackingPath(trackingPoints);
        }

        function stopTracking() {
            isTracking = false;
            cancelAnimationFrame(trackerTimer);
            setTrackingToggleLabel();
        }

        function clearTrackingOverlay(resetToggle = true) {
            isTracking = false;
            cancelAnimationFrame(trackerTimer);
            if (trackingPath) {
                trackingPath.setMap(null);
                trackingPath = null;
            }
            if (currentSegmentPath) {
                currentSegmentPath.setMap(null);
                currentSegmentPath = null;
            }
            if (trackerMarker) {
                trackerMarker.setMap(null);
                trackerMarker = null;
            }
            if (trackingStartMarker) {
                trackingStartMarker.setMap(null);
                trackingStartMarker = null;
            }
            if (trackingEndMarker) {
                trackingEndMarker.setMap(null);
                trackingEndMarker = null;
            }
            trackingTimeBadgeMarkers.forEach(marker => marker.setMap(null));
            trackingTimeBadgeMarkers = [];
            trackerIndex = 0;
            if (resetToggle) {
                setTrackingToggleLabel();
            }
        }

        function initLiveTrackingMap(center) {
            liveTrackingMap = new google.maps.Map(document.getElementById("liveTrackingMap"), {
                center,
                zoom: 15,
                mapTypeId: google.maps.MapTypeId.ROADMAP,
                disableDefaultUI: true,
                styles: [
                    { elementType: "geometry", stylers: [{ color: "#0b1424" }] },
                    { elementType: "labels.text.stroke", stylers: [{ color: "#0b1424" }] },
                    { elementType: "labels.text.fill", stylers: [{ color: "#8fa1bd" }] },
                    { featureType: "poi", elementType: "labels", stylers: [{ visibility: "off" }] },
                    { featureType: "road", elementType: "geometry", stylers: [{ color: "#1a2536" }] },
                    { featureType: "water", elementType: "geometry", stylers: [{ color: "#0a1f33" }] },
                    { featureType: "water", elementType: "labels.text.fill", stylers: [{ visibility: "off" }] },
                    { featureType: "road", elementType: "labels.text.fill", stylers: [{ visibility: "on" }] },
                    { featureType: "road", elementType: "labels.icon", stylers: [{ visibility: "off" }] },
                    { featureType: "administrative.locality", elementType: "labels.text.fill", stylers: [{ visibility: "on" }] }
                ]
            });

            const shell = document.querySelector("#liveTrackingMap")?.closest(".map-shell");
            const latAttr = shell?.getAttribute("data-lat");
            const lngAttr = shell?.getAttribute("data-lng");
            const lat = latAttr ? parseFloat(latAttr) : NaN;
            const lng = lngAttr ? parseFloat(lngAttr) : NaN;
            if (Number.isFinite(lat) && Number.isFinite(lng)) {
                updateLiveTracking(lat, lng);
            }
        }

        function setResultView(view) {
            const tabButtons = document.querySelectorAll(".tab-btn");
            const mapView = document.getElementById("mapView");
            const cardView = document.getElementById("cardView");
            const listView = document.getElementById("listView");
            const currentViewInput = document.getElementById("currentViewInput");

            tabButtons.forEach((btn) => {
                btn.classList.toggle("active", btn.getAttribute("data-view") === view);
            });

            mapView?.classList.toggle("active", view === "map");
            cardView?.classList.toggle("active", view === "card");
            listView?.classList.toggle("active", view === "list");

            if (currentViewInput) {
                currentViewInput.value = view;
            }

            document.querySelectorAll(".pagination-link").forEach((link) => {
                try {
                    const url = new URL(link.href, window.location.origin);
                    url.searchParams.set("view", view);
                    link.href = url.toString();
                } catch {
                }
            });
        }

        function updateLiveTracking(lat, lng) {
            if (!liveTrackingMap) {
                return;
            }

            const center = { lat, lng };
            liveTrackingMap.setCenter(center);
            if (liveTrackingCircle) {
                liveTrackingCircle.setMap(null);
            }
            liveTrackingCircle = new google.maps.Circle({
                strokeColor: "#5b84a2",
                strokeOpacity: 0.42,
                strokeWeight: 1,
                fillColor: "#5b84a2",
                fillOpacity: 0.1,
                map: liveTrackingMap,
                center,
                radius: 800
            });

            if (!liveTrackingMarker) {
                liveTrackingMarker = new google.maps.Marker({
                    position: center,
                    map: liveTrackingMap,
                    icon: {
                        path: google.maps.SymbolPath.CIRCLE,
                        fillColor: "#eb5757",
                        fillOpacity: 1,
                        strokeColor: "#ffffff",
                        strokeOpacity: 0.9,
                        strokeWeight: 1.5,
                        scale: 6
                    }
                });
            } else {
                liveTrackingMarker.setPosition(center);
            }

            pulseLiveMarker();
            animateLiveRadius();
        }

        function pulseLiveMarker() {
            if (!liveTrackingMarker) {
                return;
            }

            let grow = true;
            let scale = 6;
            const base = 6;
            const max = 10;
            clearInterval(liveTrackingMarker._pulseTimer);
            liveTrackingMarker._pulseTimer = setInterval(() => {
                scale = grow ? scale + 0.5 : scale - 0.5;
                if (scale >= max) {
                    grow = false;
                }
                if (scale <= base) {
                    grow = true;
                }
                const icon = liveTrackingMarker.getIcon();
                liveTrackingMarker.setIcon({ ...icon, scale });
            }, 120);
        }

        function animateLiveRadius() {
            if (!liveTrackingCircle) {
                return;
            }

            clearInterval(liveTrackingRadiusTimer);
            let radius = 800;
            const maxRadius = 1800;
            liveTrackingRadiusTimer = setInterval(() => {
                radius += 80;
                if (radius > maxRadius) {
                    radius = 800;
                }
                liveTrackingCircle.setRadius(radius);
            }, 900);
        }

        document.addEventListener("DOMContentLoaded", () => {
            setTrackingToggleLabel();
        });

        document.addEventListener("DOMContentLoaded", () => {
            const tabButtons = document.querySelectorAll(".tab-btn");
            const cardView = document.getElementById("cardView");
            const listView = document.getElementById("listView");
            const currentViewInput = document.getElementById("currentViewInput");
            const updatePaginationViewLinks = (view) => {
                document.querySelectorAll(".pagination-link").forEach((link) => {
                    try {
                        const url = new URL(link.href, window.location.origin);
                        url.searchParams.set("view", view);
                        link.href = url.toString();
                    } catch {
                    }
                });
            };

            if (currentViewInput) {
                updatePaginationViewLinks(currentViewInput.value || "map");
            }

            tabButtons.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const selectedView = btn.getAttribute("data-view") || "map";
                    setResultView(selectedView);
                });
            });
        });

        document.addEventListener("DOMContentLoaded", () => {
            const micBtn = document.getElementById("searchMicBtn");
            const input = document.getElementById("searchInput");
            const plateTypeRawInput = document.getElementById("plateTypeRawInput");
            if (!micBtn || !input) {
                return;
            }

            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SpeechRecognition) {
                micBtn.title = "Voice search not supported in this browser.";
                return;
            }

            const recognition = new SpeechRecognition();
            recognition.lang = "en-US";
            recognition.interimResults = false;
            recognition.maxAlternatives = 1;

            let isListening = false;
            let isProcessing = false;
            let lastInputSource = "manual";
            const form = input.form;

            recognition.addEventListener("start", () => {
                isListening = true;
                isProcessing = false;
                micBtn.classList.add("btn-accent");
                const hasText = (input.value || "").trim().length > 0;
                if (hasText) {
                    const typeSelect = document.getElementById("plateTypeSelect");
                    const countrySelect = document.getElementById("countrySelect");
                    const windowSelect = document.getElementById("windowSelect");
                    const deviceInput = document.getElementById("deviceIdInput");
                    if (plateTypeRawInput) {
                        plateTypeRawInput.value = "";
                    }
                    if (typeSelect) typeSelect.value = "All";
                    if (countrySelect) countrySelect.value = "All";
                    if (windowSelect) windowSelect.value = "24h";
                    if (deviceInput) deviceInput.value = "";
                }
                const status = document.getElementById("voiceStatus");
                if (status) {
                    status.textContent = "Listening...";
                }
            });

            micBtn.addEventListener("click", () => {
                recognition.start();
            });

            recognition.addEventListener("result", (event) => {
                const transcript = event.results[0][0].transcript;
                isProcessing = true;
                lastInputSource = "mic";
                const status = document.getElementById("voiceStatus");
                if (status) {
                    status.textContent = `Heard: "${transcript}" — processing...`;
                }
                const parsed = parseVoiceQuery(transcript);
                input.value = parsed.queryText;
                applyVoiceFilters(parsed);
                input.form?.submit();
            });

            recognition.addEventListener("end", () => {
                isListening = false;
                micBtn.classList.remove("btn-accent");
                const status = document.getElementById("voiceStatus");
                if (status && !isProcessing) {
                    status.textContent = "Voice input: idle";
                }
            });

            recognition.addEventListener("error", () => {
                isListening = false;
                isProcessing = false;
                micBtn.classList.remove("btn-accent");
                const status = document.getElementById("voiceStatus");
                if (status) {
                    status.textContent = "Voice input: error. Try again.";
                }
            });

            input.addEventListener("input", () => {
                if (plateTypeRawInput) {
                    plateTypeRawInput.value = "";
                }
                lastInputSource = "manual";
            });

            form?.addEventListener("submit", () => {
                const hasTypedText = (input.value || "").trim().length > 0;
                if (lastInputSource === "manual" || hasTypedText) {
                    if (plateTypeRawInput) {
                        plateTypeRawInput.value = "";
                    }
                }
            });
        });

        document.addEventListener("DOMContentLoaded", () => {
            const typeData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PlateTypeBreakdown));
            const countryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PlateCountryBreakdown));
            const vehicleData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.VehicleClassBreakdown));
            renderPieChart("plateTypeChart", "plateTypeChartDetails", typeData, ["#e8b4c2", "#5b84a2", "#bb6bd9", "#27ae60", "#c17a62"]);
            renderPieChart("plateCountryChart", "plateCountryChartDetails", countryData, ["#5b84a2", "#e8b4c2", "#eb5757", "#27ae60"]);
            renderPieChart("vehicleClassChart", "vehicleClassChartDetails", vehicleData, ["#bb6bd9", "#5b84a2", "#e8b4c2", "#27ae60", "#eb5757"]);
        });

        function renderPieChart(canvasId, detailsId, data, colors) {
            const canvas = document.getElementById(canvasId);
            const details = document.getElementById(detailsId);
            if (!canvas || !details || !data || data.length === 0) {
                return;
            }
            const labels = data.map(d => d.label ?? d.Label);
            const counts = data.map(d => d.count ?? d.Count);
            const total = counts.reduce((sum, value) => sum + value, 0);
            const detailRows = labels.map((label, index) => ({
                label,
                count: counts[index],
                color: colors[index % colors.length],
                percent: total > 0 ? Math.round((counts[index] / total) * 100) : 0
            })).sort((a, b) => b.count - a.count);

            details.innerHTML = detailRows.map(item => `
                <div class="chart-detail-item">
                    <div class="chart-detail-meta">
                        <span class="chart-swatch" style="background:${item.color}"></span>
                        <span class="chart-detail-label">${item.label}</span>
                    </div>
                    <div class="chart-detail-value">${item.count} <span>${item.percent}%</span></div>
                </div>
            `).join("");

            new Chart(canvas, {
                type: "doughnut",
                data: {
                    labels,
                    datasets: [{
                        data: counts,
                        backgroundColor: colors,
                        borderWidth: 0
                    }]
                },
                options: {
                    cutout: "70%",
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: (context) => {
                                    const value = context.raw || 0;
                                    const percent = total > 0 ? Math.round((value / total) * 100) : 0;
                                    return `${context.label}: ${value} (${percent}%)`;
                                }
                            }
                        }
                    },
                    maintainAspectRatio: false
                }
            });
        }

        document.addEventListener("DOMContentLoaded", () => {
            const ttsBtn = document.getElementById("ttsBtn");
            if (!ttsBtn || !("speechSynthesis" in window)) {
                if (ttsBtn) {
                    ttsBtn.title = "Text-to-speech not supported in this browser.";
                }
                return;
            }

            let isSpeaking = false;
            let preferredVoice = null;

            const pickVoice = () => {
                const voices = window.speechSynthesis.getVoices();
                if (!voices || voices.length === 0) {
                    return;
                }
                const female = voices.find(v =>
                    /female|woman|zira|susan|sara|jenny|aria|nora|emma|olivia|linda/i.test(v.name)
                );
                preferredVoice = female || voices[0];
            };

            pickVoice();
            window.speechSynthesis.onvoiceschanged = pickVoice;
            ttsBtn.addEventListener("click", () => {
                if (isSpeaking) {
                    window.speechSynthesis.cancel();
                    isSpeaking = false;
                    ttsBtn.textContent = "Text-to-Speech";
                    return;
                }

                const summary = document.getElementById("insideSummaryNarrative")?.textContent?.trim();
                const bullets = Array.from(document.querySelectorAll("#insideSummaryInsightList .inside-summary-insight-text"))
                    .map((el) => el.textContent?.trim())
                    .filter(Boolean);
                const text = [summary, ...bullets].filter(Boolean).join(". ");
                if (!text) {
                    return;
                }

                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = "en-US";
                utterance.rate = 0.95;
                utterance.pitch = 1.1;
                if (preferredVoice) {
                    utterance.voice = preferredVoice;
                }
                utterance.onend = () => {
                    isSpeaking = false;
                    ttsBtn.textContent = "Text-to-Speech";
                };
                utterance.onerror = () => {
                    isSpeaking = false;
                    ttsBtn.textContent = "Text-to-Speech";
                };

                isSpeaking = true;
                ttsBtn.textContent = "Stop TTS";
                window.speechSynthesis.speak(utterance);
            });
        });

        document.addEventListener("DOMContentLoaded", () => {
            const resetBtn = document.getElementById("resetFiltersBtn");
            if (!resetBtn) {
                return;
            }
            resetBtn.addEventListener("click", () => {
                const typeSelect = document.getElementById("plateTypeSelect");
                const countrySelect = document.getElementById("countrySelect");
                const windowSelect = document.getElementById("windowSelect");
                const deviceInput = document.getElementById("deviceIdInput");
                const searchInput = document.getElementById("searchInput");
                const plateTypeRawInput = document.getElementById("plateTypeRawInput");
                if (typeSelect) typeSelect.value = "All";
                if (countrySelect) countrySelect.value = "All";
                if (windowSelect) windowSelect.value = "24h";
                if (deviceInput) deviceInput.value = "";
                if (searchInput) searchInput.value = "";
                if (plateTypeRawInput) plateTypeRawInput.value = "";
            });
        });

        function parseVoiceQuery(transcript) {
            const text = transcript.toLowerCase();
            const result = {
                queryText: "",
                plateType: "",
                country: "",
                window: "",
                deviceId: ""
            };

            const plateTypeTokens = [];
            if (text.includes("taxi") || text.includes("taxis") || text.includes("taxes") || text.includes("taxies")) plateTypeTokens.push("Taxi");
            if (text.includes("transport")) plateTypeTokens.push("Transport");
            if (text.includes("commercial")) plateTypeTokens.push("Commercial");
            if (text.includes("government")) plateTypeTokens.push("Government");
            if (text.includes("private")) plateTypeTokens.push("Private");
            if (plateTypeTokens.length > 0) {
                result.plateType = plateTypeTokens.join(", ");
            }

            if (text.includes("qatar")) result.country = "Qatar";
            if (text.includes("saudi") || text.includes("ksa")) result.country = "KSA";
            if (text.includes("uae") || text.includes("emirates")) result.country = "UAE";
            if (text.includes("oman")) result.country = "Oman";

            if (text.includes("last 24") || text.includes("24 hours")) result.window = "24h";
            if (text.includes("today")) result.window = "today";
            if (text.includes("7 days") || text.includes("last 7")) result.window = "7d";

            const plateMatch = transcript.match(/[A-Z]{2,4}[-\s]?[A-Z]?\d{3,5}/i);
            if (plateMatch) {
                result.queryText = plateMatch[0].replace(/\s+/g, "");
                return result;
            }

            const deviceMatch = transcript.match(/device\s*(\d{1,4})/i);
            if (deviceMatch) {
                result.deviceId = deviceMatch[1];
            }

            const digitMatch = transcript.match(/\b(\d{2,5})\b/);
            if (digitMatch) {
                if (!result.deviceId) {
                    result.queryText = digitMatch[1];
                    return result;
                }
            }

            const keywords = [
                "taxi", "taxis", "taxes", "taxies", "transport", "commercial", "government", "private",
                "qatar", "ksa", "saudi", "uae", "emirates", "oman", "device",
                "last 24", "24 hours", "today", "7 days", "last 7"
            ];
            const hasOnlyKeywords = keywords.some(k => text.includes(k)) && text.split(" ").length <= 5;
            result.queryText = hasOnlyKeywords ? "" : transcript;

            return result;
        }

        function applyVoiceFilters(parsed) {
            const typeSelect = document.getElementById("plateTypeSelect");
            const countrySelect = document.getElementById("countrySelect");
            const windowSelect = document.getElementById("windowSelect");
            const deviceInput = document.getElementById("deviceIdInput");
            if (parsed.plateType && typeSelect) {
                const firstType = parsed.plateType.split(",")[0]?.trim();
                typeSelect.value = firstType;
            }
            const typeRawInput = document.getElementById("plateTypeRawInput");
            if (parsed.plateType && typeRawInput) {
                typeRawInput.value = parsed.plateType;
            }
            if (parsed.country && countrySelect) {
                countrySelect.value = parsed.country;
            }
            if (parsed.window && windowSelect) {
                windowSelect.value = parsed.window;
            }
            if (parsed.deviceId && deviceInput) {
                deviceInput.value = parsed.deviceId;
            }
        }

        window.initSearchMap = initSearchMap;
    </script>
    <script src="https://maps.googleapis.com/maps/api/js?key=@mapsKey&amp;libraries=visualization&amp;callback=initSearchMap&amp;loading=async" async></script>
}

