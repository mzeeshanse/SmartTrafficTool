                                </div>
                                <div class="map-popup-trans-titles">
                                    <div class="map-popup-title-row">
                                        <h4 class="map-popup-plate-title inside-summary-title">Intelligence brief</h4>
                                        <div class="map-popup-risk map-popup-risk--warn">
