            </div>
            <div class="card investigation-intel-card">
                <div class="investigation-intel-accent investigation-intel-accent--teal" aria-hidden="true"></div>
                <div class="investigation-intel-head">
                    <div class="investigation-intel-icon investigation-intel-icon--teal" aria-hidden="true"><i class="fa-solid fa-car-side"></i></div>
                    <div class="investigation-intel-head-text">
                        <h4 class="investigation-intel-title">Co-Travel Vehicles</h4>
                        <p class="investigation-intel-sub">Same time window · proximity heuristic</p>
                    </div>
                </div>
                <div class="investigation-intel-body">
                    @if (coTravelIsDemo)
                    {
                        <div class="investigation-intel-demo-banner" role="note">
                            <i class="fa-solid fa-flask" aria-hidden="true"></i>
                            <span>Illustrative matches (no live co-travel feed for this query).</span>
                        </div>
                    }
                    <ul class="investigation-intel-list">
                        @foreach (var line in coTravelDisplayList)
                        {
                            <li class="investigation-intel-row">
                                <span class="investigation-intel-row-icon" aria-hidden="true"><i class="fa-solid fa-link"></i></span>
                                <span class="investigation-intel-row-text">@line</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
            <div class="card investigation-intel-card">
                <div class="investigation-intel-accent investigation-intel-accent--warn" aria-hidden="true"></div>
                <div class="investigation-intel-head">
                    <div class="investigation-intel-icon investigation-intel-icon--warn" aria-hidden="true"><i class="fa-solid fa-user-shield"></i></div>
                    <div class="investigation-intel-head-text">
                        <h4 class="investigation-intel-title">CID / Wanted List</h4>
                        <p class="investigation-intel-sub">Flag intelligence · risk estimate</p>
                    </div>
                </div>
                <div class="investigation-intel-body">
                    <div class="investigation-intel-metrics">
                        <div class="investigation-intel-metric">
                            <span class="investigation-intel-metric-label">Flag status</span>
                            <span class="investigation-intel-metric-value @(cidWantedActive ? "investigation-intel-metric-value--danger" : "")">@Model.WantedFlag</span>
                        </div>
                        <div class="investigation-intel-metric">
                            <span class="investigation-intel-metric-label">Risk score</span>
                            <span class="investigation-intel-metric-value">@(Math.Min(Model.ViolationsCount * 12, 100))%</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card investigation-intel-card">
                <div class="investigation-intel-accent investigation-intel-accent--gold" aria-hidden="true"></div>
                <div class="investigation-intel-head">
                    <div class="investigation-intel-icon investigation-intel-icon--gold" aria-hidden="true"><i class="fa-solid fa-receipt"></i></div>
                    <div class="investigation-intel-head-text">
                        <h4 class="investigation-intel-title">Traffic Fines</h4>
                        <p class="investigation-intel-sub">Linked violations · estimated liability</p>
                    </div>
                </div>
                <div class="investigation-intel-body">
                    <div class="investigation-intel-highlight">@Model.TrafficFines</div>
                    <p class="investigation-intel-foot">Last ticket on file: <strong>2 days ago</strong> (demo ledger).</p>
                </div>
            </div>
            <div class="card investigation-intel-card">
                <div class="investigation-intel-accent investigation-intel-accent--purple" aria-hidden="true"></div>
                <div class="investigation-intel-head">
                    <div class="investigation-intel-icon investigation-intel-icon--purple" aria-hidden="true"><i class="fa-solid fa-id-card"></i></div>
                    <div class="investigation-intel-head-text">
                        <h4 class="investigation-intel-title">Owner Intelligence</h4>
                        <p class="investigation-intel-sub">Registry snapshot · points balance</p>
                    </div>
                </div>
                <div class="investigation-intel-body">
                    <div class="investigation-intel-block">
                        <span class="investigation-intel-block-label">Registered party</span>
                        <p class="investigation-intel-block-value">@Model.OwnerInfo</p>
                    </div>
                    <div class="investigation-intel-block investigation-intel-block--compact">
                        <span class="investigation-intel-block-label">License points</span>
