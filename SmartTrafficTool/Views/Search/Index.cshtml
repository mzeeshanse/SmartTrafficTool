            </div>
            <div class="card investigation-intel-card">
                <div class="investigation-intel-accent" aria-hidden="true"></div>
                <div class="investigation-intel-head">
                    <div class="investigation-intel-icon" aria-hidden="true"><i class="fa-solid fa-route"></i></div>
                    <div class="investigation-intel-head-text">
                        <h4 class="investigation-intel-title">Historical Tracking</h4>
                        <p class="investigation-intel-sub">Ordered sightings · plate <strong>@(Model.SelectedPlate ?? "N/A")</strong></p>
                    </div>
                </div>
                <div class="investigation-intel-body">
                    @if (Model.Timeline.Count == 0)
                    {
                        <div class="investigation-intel-empty">
                            <i class="fa-regular fa-map" aria-hidden="true"></i>
                            <span>No timeline rows yet. Run a plate search and open results to populate this trail.</span>
                        </div>
