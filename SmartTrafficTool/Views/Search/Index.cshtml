@model SmartTrafficTool.ViewModels.HybridSearchViewModel
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "AI Forensic Search";
    var mapsKey = Configuration["GoogleMaps:ApiKey"];
    string VehicleClassLabel(int? id) => id switch
    {
        1 => "Sedan",
        2 => "SUV",
        3 => "Pickup",
        4 => "Bus",
        5 => "Truck",
        _ => "—"
    };

    string PlateTypeLabel(int id) => id switch
    {
        1 => "Private",
        2 => "Commercial",
        3 => "Government",
        4 => "Transport",
        5 => "Taxi",
        _ => "Private"
    };

    string PlateCountryLabel(int id) => id switch
    {
        1 => "Qatar",
        2 => "UAE",
        3 => "KSA",
        4 => "Oman",
        _ => "Qatar"
    };

    var filterWindowKey = string.IsNullOrWhiteSpace(Model.FilterWindow) ? "24h" : Model.FilterWindow!;
    var filterWindowLabel = filterWindowKey switch
    {
        "24h" => "Last 24 hours",
        "48h" => "Last 48 hours",
        "today" => "Today",
        "7d" => "Last 7 days",
        _ => filterWindowKey
    };
    var queryContextLabel = string.IsNullOrWhiteSpace(Model.Query) ? "Fleet-wide scope" : $"“{Model.Query}”";

    string TransactionStatusLabel(int code) => code switch
    {
        1 => "Cleared",
        2 => "Under review",
        3 => "Violation",
        _ => "—"
    };

    string SearchListStatusPillClass(int code) => code switch
    {
        1 => "search-list-pill search-list-pill--success",
        2 => "search-list-pill search-list-pill--warn",
        3 => "search-list-pill search-list-pill--alert",
        _ => "search-list-pill search-list-pill--neutral"
    };
}

<div class="card">
    <form method="get" asp-action="Index">
        <input type="hidden" id="currentViewInput" name="view" value="@Model.CurrentView" />
        <div class="d-flex flex-wrap gap-3 align-items-center">
            <label class="investigation-mode-icon" title="Investigation Search">
                <input id="investigationModeToggle" name="investigationMode" type="checkbox" value="true" @(Model.IsInvestigationMode ? "checked" : null) />
                <span class="investigation-mode-icon-shell" aria-hidden="true">
                    <i class="fa-solid fa-user-secret"></i>
                </span>
            </label>
            <div class="flex-grow-1">
                <input id="searchInput" name="q" class="form-control search-input" type="text" value="@Model.Query" placeholder="Search plate, vehicle, zone, or case ID..." />
            </div>
            <button id="searchMicBtn" class="btn btn-ghost" type="button" aria-label="Voice search"><i class="fa-solid fa-microphone"></i></button>
            <button id="searchSubmitBtn" class="btn btn-accent" type="submit"><i class="fa-solid fa-magnifying-glass me-2"></i>Search</button>
            <button id="resetFiltersBtn" class="btn btn-ghost" type="button"><i class="fa-solid fa-rotate-left me-2"></i>Reset Filters</button>
            <button class="btn btn-ghost" type="button" data-toggle="filters"><i class="fa-solid fa-sliders me-2"></i>Filters</button>
        </div>
        <div id="voiceStatus" class="stat-label mt-2">Voice input: idle</div>
        <div class="filter-panel">
            <div class="grid grid-3 mt-3">
                <div>
                    <label class="form-label">Plate Type</label>
                    <select id="plateTypeSelect" name="plateType" class="form-select search-input">
                        <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.FilterType) || Model.FilterType == "All")">All</option>
                        <option value="Private" selected="@(Model.FilterType == "Private")">Private</option>
                        <option value="Commercial" selected="@(Model.FilterType == "Commercial")">Commercial</option>
                        <option value="Government" selected="@(Model.FilterType == "Government")">Government</option>
                        <option value="Transport" selected="@(Model.FilterType == "Transport")">Transport</option>
                        <option value="Taxi" selected="@(Model.FilterType == "Taxi")">Taxi</option>
                    </select>
                    <input type="hidden" id="plateTypeRawInput" name="plateTypeRaw" value="@Model.FilterType" />
                </div>
                <div>
                    <label class="form-label">Country</label>
                    <select id="countrySelect" name="country" class="form-select search-input">
                        <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.FilterCountry) || Model.FilterCountry == "All")">All</option>
                        <option value="Qatar" selected="@(Model.FilterCountry == "Qatar")">Qatar</option>
                        <option value="UAE" selected="@(Model.FilterCountry == "UAE")">UAE</option>
                        <option value="KSA" selected="@(Model.FilterCountry == "KSA")">KSA</option>
                        <option value="Oman" selected="@(Model.FilterCountry == "Oman")">Oman</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Time Window</label>
                    <select id="windowSelect" name="window" class="form-select search-input">
                        <option value="24h" selected="@(Model.FilterWindow == "24h")">Last 24 Hours</option>
                        <option value="48h" selected="@(Model.FilterWindow == "48h")">Last 48 Hours</option>
                        <option value="today" selected="@(Model.FilterWindow == "today")">Today</option>
                        <option value="7d" selected="@(Model.FilterWindow == "7d")">7 Days</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Device</label>
                    <select id="deviceIdInput" name="deviceId" class="form-select search-input">
                        <option value="">All</option>
                        @foreach (var device in Model.DeviceOptions)
                        {
                            <option value="@device.Id" selected="@(Model.FilterDeviceId == device.Id)">@device.Id - @device.Name</option>
                        }
                    </select>
                </div>
                <div class="filter-incident-scope">
                    <label class="form-label">Incident scope</label>
                    <div class="d-flex flex-column gap-1 small">
                        <label class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" name="alertsOnly" value="true" @(Model.FilterAlertsOnly ? "checked" : null) />
                            <span class="form-check-label">Alerts only</span>
                        </label>
                        <label class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" name="speedViolationsOnly" value="true" @(Model.FilterSpeedViolationsOnly ? "checked" : null) />
                            <span class="form-check-label">Speed violations only (≥120 km/h)</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="search-layout mt-4@(Model.IsInvestigationMode ? " search-layout--investigation" : "")">
    <div class="search-results-column">
        <div class="result-view-tabs">
            <button class="btn btn-ghost btn-sm tab-btn @(Model.CurrentView == "map" ? "active" : "")" type="button" data-view="map">Map View</button>
            <button class="btn btn-ghost btn-sm tab-btn @(Model.CurrentView == "card" ? "active" : "")" type="button" data-view="card">Card View</button>
            <button class="btn btn-ghost btn-sm tab-btn @(Model.CurrentView == "list" ? "active" : "")" type="button" data-view="list">List View</button>
        </div>

        <div id="mapView" class="result-view @(Model.CurrentView == "map" ? "active" : "")">
            <div class="card common-map-section result-panel-card">
                <div class="map-shell search-main-map-shell">
                    <div id="searchMap" class="map-canvas"></div>
                    <div class="map-overlay">
                        @* <div class="map-title">View on Map</div>
                        <div class="stat-label">Shared situational map for standard and investigation search.</div> *@
                    </div>
                </div>
            </div>
        </div>

        <div id="cardView" class="result-view @(Model.CurrentView == "card" ? "active" : "")">
            <div class="card result-panel-card">
                <div class="result-panel-body">
                    <div class="grid results-grid @(Model.IsInvestigationMode ? "" : "results-grid--standard")">
                        @foreach (var item in Model.Results)
                        {
                            var plate = item.Transaction.PLATE_TEXT ?? "—";
                            var vehicleClass = VehicleClassLabel(item.Classification?.VEH_TYPE_ID);
                            var plateType = PlateTypeLabel(item.Transaction.PLATE_TYPE_ID);
                            var country = PlateCountryLabel(item.Transaction.PLATE_ORIGIN_ID);
                            var subtitle = $"{plateType} · {vehicleClass}";
                            var isAlert = item.Transaction.IS_ALERTED;
                            var riskClass = isAlert ? "map-popup-risk--high" : "map-popup-risk--low";
                            var riskLabel = isAlert ? "High risk" : "Standard";
                            var flagCount = isAlert ? "1" : "0";
                            var localCap = item.Transaction.CREATED_DATE_TIME.ToLocalTime();
                            var capturedShort = localCap.ToString("MMM d, hh:mm tt");
                            var capturedDetail = localCap.ToString("M/d/yyyy, h:mm:ss tt");
                            var deviceLabel = item.Device?.Name ?? $"Device {item.Transaction.DEVICE_ID}";
                            var speedVal = item.Transaction.SPEED;
                            var speedText = $"{speedVal} km/h";
                            <div class="transaction-result-wrap">
                                <article class="map-popup-card map-popup-card--transaction transaction-result-card">
                                    <div class="map-popup-media">
                                        <img class="map-popup-image" src="/images/anpr/Anpr1.jpg" alt="Transaction frame" />
                                        <div class="map-popup-plate-crop">
                                            <div class="map-popup-plate-text">@plate</div>
                                        </div>
                                    </div>
                                    <div class="map-popup-body">
                                        <div class="map-popup-trans-head">
                                            <div class="map-popup-trans-head-main">
                                                <div class="map-popup-veh-icon" aria-hidden="true">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2" />
                                                        <circle cx="7" cy="17" r="2" /><path d="M9 17h6" /><circle cx="17" cy="17" r="2" />
                                                    </svg>
                                                </div>
                                                <div class="map-popup-trans-titles">
                                                    <div class="map-popup-title-row">
                                                        <h4 class="map-popup-plate-title">@plate</h4>
                                                        <div class="map-popup-risk @riskClass">
                                                            <span class="map-popup-risk-dot" aria-hidden="true"></span>
                                                            <span class="map-popup-risk-text">@riskLabel</span>
                                                        </div>
                                                    </div>
                                                    <p class="map-popup-trans-sub">@subtitle</p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="map-popup-kpis">
                                            <div class="map-popup-kpi">
                                                <span class="map-popup-kpi-label">Class</span>
                                                <span class="map-popup-kpi-value">@vehicleClass</span>
                                            </div>
                                            <div class="map-popup-kpi">
                                                <span class="map-popup-kpi-label">Origin</span>
                                                <span class="map-popup-kpi-value">@country</span>
                                            </div>
                                            <div class="map-popup-kpi">
                                                <span class="map-popup-kpi-label">Flags</span>
                                                <span class="map-popup-kpi-value">@flagCount</span>
                                            </div>
                                        </div>
                                        <div class="map-popup-pill-row">
                                            @if (isAlert)
                                            {
                                                <span class="map-popup-pill map-popup-pill--danger">Alert detection</span>
                                            }
                                            @if (speedVal >= 120)
                                            {
                                                <span class="map-popup-pill map-popup-pill--warn">High speed</span>
                                            }
                                            @if (!isAlert && speedVal < 120)
                                            {
                                                <span class="map-popup-pill map-popup-pill--neutral">ANPR read</span>
                                            }
                                        </div>
                                        <div class="map-popup-trans-meta-row">
                                            <span class="map-popup-meta-item"><i class="fa-solid fa-location-dot" aria-hidden="true"></i>@deviceLabel</span>
                                            <span class="map-popup-meta-item"><i class="fa-regular fa-clock" aria-hidden="true"></i>@capturedShort</span>
                                        </div>
                                        <p class="map-popup-trans-detail">Captured @capturedDetail · Speed @speedText · Status @item.Transaction.TRANSACTION_STATUS</p>
                                        <div class="map-popup-trans-actions">
                                            <button class="map-popup-foot-btn view-on-map-btn"
                                                    type="button"
                                                    data-plate="@(item.Transaction.PLATE_TEXT ?? string.Empty)"
                                                    data-lat="@(item.Device?.Latitude)"
                                                    data-lng="@(item.Device?.Longitude)"
                                                    data-time="@item.Transaction.CREATED_DATE_TIME.ToString("o")"
                                                    data-device="@deviceLabel">View on map</button>
                                            <a class="map-popup-foot-btn map-popup-foot-btn--ghost" asp-controller="Cases" asp-action="Index">Add to case</a>
                                            @if (Model.IsInvestigationMode)
                                            {
                                                <button class="map-popup-foot-btn map-popup-foot-btn--accent live-track-btn"
                                                        type="button"
                                                        data-plate="@(item.Transaction.PLATE_TEXT ?? string.Empty)"
                                                        data-lat="@(item.Device?.Latitude)"
                                                        data-lng="@(item.Device?.Longitude)">Live tracking</button>
                                            }
                                        </div>
                                    </div>
                                </article>
                            </div>
                        }
                    </div>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="result-panel-footer">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="stat-label">Page @Model.CurrentPage of @Model.TotalPages</span>
                            <div class="d-flex gap-2">
                                <a class="btn btn-ghost btn-sm pagination-link @(Model.CurrentPage <= 1 ? "disabled" : string.Empty)"
                                   asp-action="Index"
                                   asp-route-q="@Model.Query"
                                   asp-route-plateType="@Model.FilterType"
                                   asp-route-country="@Model.FilterCountry"
                                   asp-route-window="@Model.FilterWindow"
                                   asp-route-deviceId="@Model.FilterDeviceId"
                                   asp-route-alertsOnly="@Model.FilterAlertsOnly"
                                   asp-route-speedViolationsOnly="@Model.FilterSpeedViolationsOnly"
                                   asp-route-investigationMode="@Model.IsInvestigationMode"
                                   asp-route-view="@Model.CurrentView"
                                   asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                                <a class="btn btn-ghost btn-sm pagination-link @(Model.CurrentPage >= Model.TotalPages ? "disabled" : string.Empty)"
                                   asp-action="Index"
                                   asp-route-q="@Model.Query"
                                   asp-route-plateType="@Model.FilterType"
                                   asp-route-country="@Model.FilterCountry"
                                   asp-route-window="@Model.FilterWindow"
                                   asp-route-deviceId="@Model.FilterDeviceId"
                                   asp-route-alertsOnly="@Model.FilterAlertsOnly"
                                   asp-route-speedViolationsOnly="@Model.FilterSpeedViolationsOnly"
                                   asp-route-investigationMode="@Model.IsInvestigationMode"
                                   asp-route-view="@Model.CurrentView"
                                   asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div id="listView" class="result-view search-list-view @(Model.CurrentView == "list" ? "active" : "")">
            <div class="card result-panel-card search-list-panel">
                <div class="result-panel-body result-table-body">
                    <div class="table-responsive search-list-table-wrap">
                        <table class="table table-dark table-hover align-middle search-results-table">
                            <thead>
                                <tr>
                                    <th scope="col" class="search-list-th">Plate</th>
                                    <th scope="col" class="search-list-th">Device</th>
                                    <th scope="col" class="search-list-th search-list-th--num">Speed</th>
                                    <th scope="col" class="search-list-th">Status</th>
                                    <th scope="col" class="search-list-th">Alert</th>
                                    <th scope="col" class="search-list-th">Captured</th>
                                    <th scope="col" class="search-list-th">Vehicle</th>
                                    <th scope="col" class="search-list-th search-list-th--actions"><span class="visually-hidden">Actions</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Results)
                                {
                                    var deviceLabel = item.Device?.Name ?? $"Device {item.Transaction.DEVICE_ID}";
                                    var capLocal = item.Transaction.CREATED_DATE_TIME.ToLocalTime();
                                    <tr class="search-list-row">
                                        <td class="search-list-td search-list-td--plate">
                                            <span class="search-list-plate">@(item.Transaction.PLATE_TEXT ?? "Unknown")</span>
                                        </td>
                                        <td class="search-list-td">
                                            <span class="search-list-device-name">@deviceLabel</span>
                                            <span class="search-list-device-id">#@item.Transaction.DEVICE_ID</span>
                                        </td>
                                        <td class="search-list-td search-list-td--speed">
                                            <span class="search-list-speed">@item.Transaction.SPEED</span><span class="search-list-speed-unit"> km/h</span>
                                        </td>
                                        <td class="search-list-td">
                                            <span class="@SearchListStatusPillClass(item.Transaction.TRANSACTION_STATUS)">@TransactionStatusLabel(item.Transaction.TRANSACTION_STATUS)</span>
                                        </td>
                                        <td class="search-list-td">
                                            @if (item.Transaction.IS_ALERTED)
                                            {
                                                <span class="search-list-pill search-list-pill--alert"><i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>Alert</span>
                                            }
                                            else
                                            {
                                                <span class="search-list-pill search-list-pill--ok"><i class="fa-solid fa-shield-check" aria-hidden="true"></i>Clear</span>
                                            }
                                        </td>
                                        <td class="search-list-td search-list-td--time">
                                            <span class="search-list-time">@capLocal.ToString("MMM d, yyyy")</span>
                                            <span class="search-list-time-sub">@capLocal.ToString("h:mm tt")</span>
                                        </td>
                                        <td class="search-list-td search-list-td--class">@VehicleClassLabel(item.Classification?.VEH_TYPE_ID)</td>
                                        <td class="search-list-td search-list-td--actions">
                                            <div class="search-list-actions">
                                                <button class="btn btn-ghost btn-sm search-list-action-btn view-on-map-btn"
                                                        type="button"
                                                        data-plate="@(item.Transaction.PLATE_TEXT ?? string.Empty)"
                                                        data-lat="@(item.Device?.Latitude)"
                                                        data-lng="@(item.Device?.Longitude)"
                                                        data-time="@item.Transaction.CREATED_DATE_TIME.ToString("o")"
                                                        data-device="@(item.Device?.Name ?? "Device")"><i class="fa-solid fa-map-location-dot me-1" aria-hidden="true"></i>View on Map</button>
                                                @if (Model.IsInvestigationMode)
                                                {
                                                    <button class="btn btn-ghost btn-sm search-list-action-btn live-track-btn"
                                                            type="button"
                                                            data-plate="@(item.Transaction.PLATE_TEXT ?? string.Empty)"
                                                            data-lat="@(item.Device?.Latitude)"
                                                            data-lng="@(item.Device?.Longitude)"><i class="fa-solid fa-location-crosshairs me-1" aria-hidden="true"></i>Live Tracking</button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                @if (Model.TotalPages > 1)
                {
                    <div class="result-panel-footer">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="stat-label">Page @Model.CurrentPage of @Model.TotalPages</span>
                            <div class="d-flex gap-2">
                                <a class="btn btn-ghost btn-sm pagination-link @(Model.CurrentPage <= 1 ? "disabled" : string.Empty)"
                                   asp-action="Index"
                                   asp-route-q="@Model.Query"
                                   asp-route-plateType="@Model.FilterType"
                                   asp-route-country="@Model.FilterCountry"
                                   asp-route-window="@Model.FilterWindow"
                                   asp-route-deviceId="@Model.FilterDeviceId"
                                   asp-route-alertsOnly="@Model.FilterAlertsOnly"
                                   asp-route-speedViolationsOnly="@Model.FilterSpeedViolationsOnly"
                                   asp-route-investigationMode="@Model.IsInvestigationMode"
                                   asp-route-view="@Model.CurrentView"
                                   asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                                <a class="btn btn-ghost btn-sm pagination-link @(Model.CurrentPage >= Model.TotalPages ? "disabled" : string.Empty)"
                                   asp-action="Index"
                                   asp-route-q="@Model.Query"
                                   asp-route-plateType="@Model.FilterType"
                                   asp-route-country="@Model.FilterCountry"
                                   asp-route-window="@Model.FilterWindow"
                                   asp-route-deviceId="@Model.FilterDeviceId"
                                   asp-route-alertsOnly="@Model.FilterAlertsOnly"
                                   asp-route-speedViolationsOnly="@Model.FilterSpeedViolationsOnly"
                                   asp-route-investigationMode="@Model.IsInvestigationMode"
                                   asp-route-view="@Model.CurrentView"
                                   asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    @if (!Model.IsInvestigationMode)
    {
        <aside class="search-insides-column investigation-section search-summary-sidebar" aria-label="Summary and charts">
            <div class="card search-summary-card investigation-summary-card">
                <h4 class="section-title section-title--sidebar"><i class="fa-solid fa-file-shield"></i><span>Inside Summary</span></h4>
                <article class="map-popup-card map-popup-card--transaction map-popup-card--inside-summary inside-summary-card inside-summary--sidebar" aria-label="Inside summary">
                    <div class="inside-summary-accent" aria-hidden="true"></div>
                    <div class="map-popup-body">
                        <div class="map-popup-trans-head inside-summary-head">
                            <div class="map-popup-trans-head-main">
                                <div class="map-popup-veh-icon inside-summary-icon" aria-hidden="true">
                                    <i class="fa-solid fa-file-shield"></i>
                                </div>
                                <div class="map-popup-trans-titles">
                                    <div class="map-popup-title-row">
                                        <h4 class="map-popup-plate-title inside-summary-title">Intelligence brief</h4>
                                    </div>
                                    <p class="map-popup-trans-sub inside-summary-sub">
                                        @Model.TotalResults.ToString("N0") result(s) · @filterWindowLabel · @queryContextLabel
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="map-popup-kpis inside-summary-kpis">
                            <div class="map-popup-kpi">
                                <span class="map-popup-kpi-label">Total reads</span>
                                <span class="map-popup-kpi-value">@Model.TotalResults.ToString("N0")</span>
                            </div>
                            <div class="map-popup-kpi">
                                <span class="map-popup-kpi-label">Distinct plates</span>
                                <span class="map-popup-kpi-value">@Model.DistinctPlates.ToString("N0")</span>
                            </div>
                            <div class="map-popup-kpi">
                                <span class="map-popup-kpi-label">Alerts</span>
                                <span class="map-popup-kpi-value">@Model.AlertCount.ToString("N0")</span>
                            </div>
                        </div>
                        <p class="inside-summary-narrative" id="insideSummaryNarrative">@Model.SummaryText</p>
                        @if (Model.InsightBullets.Count > 0)
                        {
                            <div class="inside-summary-insights">
                                <div class="inside-summary-insights-label">Highlights</div>
                                <ul class="inside-summary-insight-list" id="insideSummaryInsightList">
                                    @foreach (var insight in Model.InsightBullets)
                                    {
                                        <li>
                                            <span class="inside-summary-insight-icon" aria-hidden="true"><i class="fa-solid fa-bolt"></i></span>
                                            <span class="inside-summary-insight-text">@insight</span>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </article>
                <div class="mt-3 d-flex gap-2 flex-wrap inside-summary-actions">
                    <button class="btn btn-accent btn-sm" type="button"><i class="fa-solid fa-file-export me-2"></i>Generate Case File</button>
                    <button id="ttsBtn" class="btn btn-ghost btn-sm" type="button"><i class="fa-solid fa-volume-high me-2"></i>Text-to-Speech</button>
                </div>
            </div>
            <div class="search-sidebar-metrics-stack">
                <div class="card search-sidebar-metric-card">
                    <div class="stat-label">Plate Type</div>
                    <div class="micro-chart">
                        <canvas id="plateTypeChart"></canvas>
                    </div>
