        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let searchMap;
        let searchMarkers = [];
        let searchInfoWindow;
        let searchHeatmap = null;

        const SEARCH_HEAT_GRADIENT = [
            "rgba(8, 12, 22, 0)",
            "rgba(8, 12, 22, 0)",
            "rgba(44, 69, 92, 0.48)",
            "rgba(62, 93, 122, 0.78)",
            "rgba(62, 110, 148, 0.9)",
            "rgba(158, 45, 72, 0.94)",
            "rgba(242, 153, 74, 0.97)",
            "rgba(235, 87, 87, 0.98)",
            "rgba(192, 35, 35, 1)",
            "rgba(153, 12, 12, 1)",
            "rgba(90, 0, 0, 1)"
        ];

        function transactionHitTargetIcon() {
            return {
                path: google.maps.SymbolPath.CIRCLE,
                scale: 18,
                fillOpacity: 0,
                strokeOpacity: 0,
                strokeWeight: 0
            };
        }

        function buildSearchHeatmapWeightedData(groups) {
            return groups.map((records) => ({
                location: new google.maps.LatLng(records[0].lat, records[0].lng),
                weight: records.length
            }));
        }
        let trackingPath;
        let currentSegmentPath;
        let trackerMarker;
        let trackingStartMarker;
        let trackingEndMarker;
        let trackingTimeBadgeMarkers = [];
        let trackerTimer;
        let trackerIndex = 0;
        let trackingPoints = [];
        let isTracking = false;
        let liveTrackingMap;
        let liveTrackingCircle;
        let liveTrackingMarker;
        let liveTrackingRadiusTimer;
        let trackingToggleControl;
        const searchAllowsPlateTracking = @(Model.IsPlateQuery ? "true" : "false");
        /** Intermediate "Record Time" badges on the journey path show only when zoom is strictly greater than this. */
        const SEARCH_RECORD_TIME_MIN_ZOOM = 14;
        let mapPopupAnchorMarker = null;

        function syncTrackingTimeBadgeVisibility() {
            if (!searchMap || !trackingTimeBadgeMarkers.length) {
                return;
            }
            const z = searchMap.getZoom();
            const show = typeof z === "number" && z > SEARCH_RECORD_TIME_MIN_ZOOM;
            const targetMap = show ? searchMap : null;
            trackingTimeBadgeMarkers.forEach((marker) => {
                marker.setMap(targetMap);
            });
        }

        function mapPopupPositionKey(lat, lng) {
            return `${Number(lat).toFixed(5)}_${Number(lng).toFixed(5)}`;
        }

        function groupMarkersByPosition(allMarkers) {
            const bucket = new Map();
            allMarkers.forEach((d) => {
                if (!Number.isFinite(d.lat) || !Number.isFinite(d.lng)) {
                    return;
                }
                const k = mapPopupPositionKey(d.lat, d.lng);
                if (!bucket.has(k)) {
                    bucket.set(k, []);
                }
                bucket.get(k).push(d);
            });
            const groups = [];
            bucket.forEach((records) => {
                records.sort((a, b) => new Date(b.time) - new Date(a.time));
                groups.push(records);
            });
            return groups;
        }

        function openSearchMarkerPopup(marker) {
            const records = marker.__popupRecords;
            if (!records || records.length === 0) {
                return;
            }
            let idx = marker.__popupIndex ?? 0;
            idx = Math.max(0, Math.min(idx, records.length - 1));
            marker.__popupIndex = idx;
            mapPopupAnchorMarker = marker;
            searchInfoWindow.setContent(buildMapPopupCard(records[idx], idx, records.length));
            searchInfoWindow.open(searchMap, marker);
        }

        function initSearchMap() {
            const dohaCenter = { lat: 25.2867, lng: 51.5333 };
            searchMap = new google.maps.Map(document.getElementById("searchMap"), {
                center: dohaCenter,
                zoom: 15,
                mapTypeId: google.maps.MapTypeId.ROADMAP,
                streetViewControl: false,
                mapTypeControl: true,
                mapTypeControlOptions: {
                    style: google.maps.MapTypeControlStyle.DEFAULT,
                    position: google.maps.ControlPosition.LEFT_TOP,
                    mapTypeIds: [
                        google.maps.MapTypeId.ROADMAP,
                        google.maps.MapTypeId.SATELLITE
                    ]
                },
                zoomControl: true,
                zoomControlOptions: {
                    position: google.maps.ControlPosition.RIGHT_CENTER
                },
                fullscreenControl: true,
                fullscreenControlOptions: {
                    position: google.maps.ControlPosition.RIGHT_TOP
                },
                controlSize: 40,
                styles: [
                    { elementType: "geometry", stylers: [{ color: "#0b1424" }] },
                    { elementType: "labels.text.stroke", stylers: [{ color: "#0b1424" }] },
                    { elementType: "labels.text.fill", stylers: [{ color: "#8fa1bd" }] },
                    { featureType: "administrative", elementType: "geometry", stylers: [{ color: "#223149" }] },
                    { featureType: "administrative", elementType: "labels.text.fill", stylers: [{ visibility: "off" }] },
                    { featureType: "poi", elementType: "geometry", stylers: [{ color: "#101c30" }] },
                    { featureType: "poi", elementType: "labels", stylers: [{ visibility: "off" }] },
                    { featureType: "road", elementType: "geometry", stylers: [{ color: "#1a2536" }] },
                    { featureType: "road.highway", elementType: "geometry", stylers: [{ color: "#283349" }] },
                    { featureType: "transit", elementType: "geometry", stylers: [{ color: "#162233" }] },
                    { featureType: "transit", elementType: "labels", stylers: [{ visibility: "off" }] },
                    { featureType: "water", elementType: "geometry", stylers: [{ color: "#0a1f33" }] },
                    { featureType: "water", elementType: "labels.text.fill", stylers: [{ visibility: "off" }] },
                    { featureType: "road", elementType: "labels.text.fill", stylers: [{ visibility: "on" }] },
                    { featureType: "road", elementType: "labels.icon", stylers: [{ visibility: "off" }] },
                    { featureType: "administrative.locality", elementType: "labels.text.fill", stylers: [{ visibility: "on" }] }
                ]
            });

            initTrackingControl();
            searchInfoWindow = new google.maps.InfoWindow({ maxWidth: 400 });
            google.maps.event.addListener(searchInfoWindow, "domready", bindPopupInteractions);
            searchMap.addListener("zoom_changed", () => {
                searchInfoWindow?.close();
                syncTrackingTimeBadgeVisibility();
            });
            loadSearchMarkers();
            initLiveTrackingMap(dohaCenter);

            document.querySelectorAll(".view-on-map-btn").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const lat = parseFloat(btn.getAttribute("data-lat"));
                    const lng = parseFloat(btn.getAttribute("data-lng"));
                    if (Number.isFinite(lat) && Number.isFinite(lng)) {
                        focusSearchMarker(lat, lng, btn.getAttribute("data-plate") || "Plate");
                    }
                });
            });

            document.querySelectorAll(".live-track-btn").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const lat = parseFloat(btn.getAttribute("data-lat"));
                    const lng = parseFloat(btn.getAttribute("data-lng"));
                    if (Number.isFinite(lat) && Number.isFinite(lng)) {
                        updateLiveTracking(lat, lng);
                    }
                });
            });
        }

        function loadSearchMarkers() {
            trackingPoints = [];
            fetchAllSearchMarkers().then((allMarkers) => {
                if (searchHeatmap) {
                    searchHeatmap.setMap(null);
                    searchHeatmap = null;
                }
                searchMarkers.forEach((m) => m.setMap(null));
                searchMarkers = [];

                allMarkers.forEach((markerData) => {
                    if (searchAllowsPlateTracking && markerData.time) {
                        trackingPoints.push({
                            lat: markerData.lat,
                            lng: markerData.lng,
                            time: new Date(markerData.time)
                        });
                    }
                });

                const groups = groupMarkersByPosition(allMarkers);
                groups.forEach((records) => addSearchMarkerGroup(records));

                if (searchMarkers.length > 0) {
                    const first = searchMarkers[0].getPosition();
                    updateLiveTracking(first.lat(), first.lng());
                }

                const viz = google.maps.visualization;
                if (viz && groups.length > 0) {
                    const maxWeight = Math.max(...groups.map((g) => g.length), 1);
                    searchHeatmap = new viz.HeatmapLayer({
                        data: buildSearchHeatmapWeightedData(groups),
                        map: searchMap,
                        dissipating: true,
                        radius: 46,
                        opacity: 0.92,
                        maxIntensity: Math.max(maxWeight * 0.88, 1),
                        gradient: SEARCH_HEAT_GRADIENT
                    });
                }
            });

            document.querySelectorAll(".view-on-map-btn").forEach((btn) => {
                const lat = parseFloat(btn.getAttribute("data-lat"));
                const lng = parseFloat(btn.getAttribute("data-lng"));
                if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
                    return;
                }
                btn.addEventListener("click", () => {
                    focusSearchMarker(lat, lng, btn.getAttribute("data-plate") || "Plate");
                });
            });
        }

        function focusSearchMarker(lat, lng, plate) {
            setResultView("map");
            searchMap.panTo({ lat, lng });
            searchMap.setZoom(15);
            const marker = searchMarkers.find(m =>
                Math.abs(m.getPosition().lat() - lat) < 0.0001 &&
                Math.abs(m.getPosition().lng() - lng) < 0.0001
            );
            if (marker) {
                const records = marker.__popupRecords || [];
                const want = (plate || "").trim().toLowerCase();
                let idx = 0;
                if (want) {
                    const found = records.findIndex((r) => {
                        const p = (r.plate || "").toLowerCase();
                        return p === want || p.includes(want) || want.includes(p);
                    });
                    if (found >= 0) {
                        idx = found;
                    }
                }
                marker.__popupIndex = idx;
                openSearchMarkerPopup(marker);
            }
        }

        async function fetchAllSearchMarkers() {
            const response = await fetch("@Url.Action("MapMarkers", "Search")?q=@Model.Query&plateType=@Model.FilterType&country=@Model.FilterCountry&window=@Model.FilterWindow&deviceId=@Model.FilterDeviceId&alertsOnly=@Model.FilterAlertsOnly&speedViolationsOnly=@Model.FilterSpeedViolationsOnly");
            if (!response.ok) {
                return [];
            }
            return await response.json();
        }

        function addSearchMarkerGroup(records) {
            if (!records || records.length === 0) {
                return;
            }
            const anchor = records[0];
            const title = records.length > 1
                ? `${records.length} detections at this location`
                : (anchor.plate || "Plate");
            const marker = new google.maps.Marker({
                position: { lat: anchor.lat, lng: anchor.lng },
                map: searchMap,
                title,
                icon: transactionHitTargetIcon(),
                optimized: false,
                zIndex: 1000000
            });
            marker.__popupRecords = records;
            marker.__popupIndex = 0;
            marker.addListener("click", () => {
                marker.__popupIndex = 0;
                openSearchMarkerPopup(marker);
            });
            searchMarkers.push(marker);
        }

        function isInvestigationSearchOn() {
            const toggle = document.getElementById("investigationModeToggle");
            if (toggle) {
                return toggle.checked;
            }
            return @(Model.IsInvestigationMode ? "true" : "false");
        }

        function buildMapPopupCard(data, recordIndex = 0, recordTotal = 1) {
            const plate = escapeHtml(data.plate || "Plate");
            const device = escapeHtml(data.device || "Device");
            const captured = data.time
                ? new Date(data.time).toLocaleString(undefined, {
                    month: "numeric",
                    day: "numeric",
                    year: "numeric",
                    hour: "numeric",
                    minute: "2-digit",
                    second: "2-digit",
                    hour12: true
                })
                : "Unknown";
            const capturedShort = data.time
                ? new Date(data.time).toLocaleString(undefined, {
                    month: "short",
                    day: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                    hour12: true
                })
                : "—";
            const vehicle = escapeHtml(data.vehicle || "—");
            const plateType = escapeHtml(data.plateType || "—");
            const country = escapeHtml(data.country || "—");
            const status = escapeHtml(`${data.status ?? "—"}`);
            const isAlert = !!data.alert;
            const speed = Number.isFinite(data.speed) ? `${data.speed} km/h` : "—";
            const riskClass = isAlert ? "map-popup-risk--high" : "map-popup-risk--low";
            const riskLabel = isAlert ? "High risk" : "Standard";
            const flagCount = isAlert ? "1" : "0";
            const subtitle = `${plateType} · ${vehicle}`;
            const liveTrackingButtonHtml = isInvestigationSearchOn()
                ? "<button class=\"map-popup-foot-btn map-popup-foot-btn--accent popup-live-track-btn\" type=\"button\">Live tracking</button>"
                : "";
            const showNav = recordTotal > 1;
            const navHtml = showNav
                ? `<div class="map-popup-nav">
                        <button type="button" class="map-popup-nav-btn map-popup-nav-prev">Previous</button>
                        <span class="map-popup-nav-index">${recordIndex + 1} / ${recordTotal}</span>
                        <button type="button" class="map-popup-nav-btn map-popup-nav-next">Next</button>
                   </div>`
                : "";
            const tagRisk = isAlert
                ? "<span class=\"map-popup-pill map-popup-pill--danger\">Alert detection</span>"
                : "";
            const speedNum = Number.isFinite(data.speed) ? data.speed : 0;
            let tagSecond = "";
            if (speedNum >= 120) {
                tagSecond = "<span class=\"map-popup-pill map-popup-pill--warn\">High speed</span>";
            } else if (!isAlert) {
                tagSecond = "<span class=\"map-popup-pill map-popup-pill--neutral\">ANPR read</span>";
            }

            return `
                <div class="map-popup-card map-popup-card--transaction" data-lat="${data.lat}" data-lng="${data.lng}">
                    <div class="map-popup-media">
                        <img class="map-popup-image" src="/images/anpr/Anpr1.jpg" alt="Transaction frame" />
                        <div class="map-popup-plate-crop">
                            <div class="map-popup-plate-text">${plate}</div>
                        </div>
                    </div>
                    <div class="map-popup-body">
                        ${navHtml}
                        <div class="map-popup-trans-head">
                            <div class="map-popup-trans-head-main">
                                <div class="map-popup-veh-icon" aria-hidden="true">
