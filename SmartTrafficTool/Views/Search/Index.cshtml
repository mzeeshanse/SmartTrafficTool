                                        @Model.TotalResults.ToString("N0") result(s) · @filterWindowLabel · @queryContextLabel
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="map-popup-kpis inside-summary-kpis">
                            <div class="map-popup-kpi">
                                <span class="map-popup-kpi-label">Total reads</span>
                                <span class="map-popup-kpi-value">@Model.TotalResults.ToString("N0")</span>
                            </div>
                            <div class="map-popup-kpi">
                                <span class="map-popup-kpi-label">Distinct plates</span>
                                <span class="map-popup-kpi-value">@Model.DistinctPlates.ToString("N0")</span>
                            </div>
                            <div class="map-popup-kpi">
                                <span class="map-popup-kpi-label">Alerts</span>
                                <span class="map-popup-kpi-value">@Model.AlertCount.ToString("N0")</span>
                            </div>
                        </div>
                        <p class="inside-summary-narrative" id="insideSummaryNarrative">@Model.SummaryText</p>
                        @if (Model.InsightBullets.Count > 0)
                        {
                            <div class="inside-summary-insights">
