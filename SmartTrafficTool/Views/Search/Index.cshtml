                    else
                    {
                        <ul class="investigation-intel-timeline">
                            @foreach (var entry in Model.Timeline)
                            {
                                <li class="investigation-intel-timeline-item">
                                    <span class="investigation-intel-timeline-dot" aria-hidden="true"></span>
                                    <span class="investigation-intel-timeline-text">@entry</span>
                                </li>
                            }
