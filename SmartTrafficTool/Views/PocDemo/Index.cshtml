@model SmartTrafficTool.ViewModels.PocRouteSimulatorViewModel
@{
    ViewData["Title"] = L["Title_PocRouteSimulator"].Value;
    ViewData["PageSubtitle"] = L["Poc_PageSubtitleDefault"].Value;
    var initialPathJson = JsonSerializer.Serialize(Model.PathDeviceIds ?? []);
    var pocI18nJson = JsonSerializer.Serialize(new
    {
        deviceFmt = L["Poc_DeviceNumberFmt"].Value,
        moveUp = L["Poc_ButtonMoveUp"].Value,
        moveDown = L["Poc_ButtonMoveDown"].Value,
        remove = L["Poc_ButtonRemove"].Value,
    });
}

@if (TempData["PocDemoSuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success mb-4" role="status">@ok</div>
}

@if (TempData["PocDemoError"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger mb-4" role="alert">@err</div>
}

<div class="card mb-4">
    <h2 class="section-title mb-2"><i class="fa-solid fa-route me-2" aria-hidden="true"></i>@L["Poc_PageTitleHeading"]</h2>
    <p class="stat-label mb-4">@L["Poc_PageIntroParagraph"]</p>

    <div class="poc-saved-path-toolbar glass p-3 rounded-3 border border-secondary border-opacity-25 mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label mb-1" for="pocSavedRouteSelect">@L["Poc_SavedPathsLabel"]</label>
                <select id="pocSavedRouteSelect" class="form-select form-select-sm">
                    <option value="">@L["Poc_SelectSavedPath"]</option>
                    @foreach (var s in Model.SavedPaths)
                    {
                        var cnt = string.Format(CultureInfo.CurrentUICulture, L["Poc_CameraCountFmt"].Value, s.CameraCount);
                        if (Model.SelectedSavedRouteId == s.Id)
                        {
                            <option value="@s.Id" data-device-ids="@s.DeviceIdsCsv" selected="selected">@s.Name (@cnt)</option>
                        }
                        else
                        {
                            <option value="@s.Id" data-device-ids="@s.DeviceIdsCsv">@s.Name (@cnt)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6 d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-outline-light btn-sm" id="pocLoadSavedBtn" title="@L["Poc_LoadPathTooltip"]">
                    <i class="fa-solid fa-folder-open me-1" aria-hidden="true"></i>@L["Poc_LoadPath"]
                </button>
                <a class="btn btn-ghost btn-sm" asp-action="Index" title="@L["Poc_ResetViewTooltip"]">@L["Poc_ResetView"]</a>
            </div>
        </div>
    </div>

    <form asp-action="Generate" method="post" id="pocRouteForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">@L["Poc_LabelCameraPathOrdered"]</label>
            <div class="poc-path-builder glass p-3 rounded-3 border border-secondary border-opacity-25">
                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-8">
                        <select id="pocPickDevice" class="form-select form-select-sm">
                            <option value="">@L["Poc_SelectCameraToAdd"]</option>
                            @foreach (var d in Model.AnprCameras)
                            {
                                <option value="@d.Id">@d.Id — @d.Name (@d.LocationDescription)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="button" class="btn btn-outline-light btn-sm flex-grow-1" id="pocAddDevice">@L["Poc_AddToPath"]</button>
                        <button type="button" class="btn btn-ghost btn-sm" id="pocClearPath" title="@L["Poc_ClearPathTooltip"]">@L["Poc_ClearPath"]</button>
                    </div>
                </div>
                <ul id="pocPathList" class="list-group list-group-flush poc-path-list mb-0"></ul>
                <p id="pocPathEmpty" class="stat-label mb-0 mt-2 @((Model.PathDeviceIds?.Count ?? 0) > 0 ? "d-none" : "")">@L["Poc_NoCamerasInPath"]</p>
                <div id="pocPathFields"></div>
            </div>
            <span asp-validation-for="PathDeviceIds" class="text-danger small"></span>
        </div>

        <div class="grid grid-2 mb-3">
            <div>
                <label asp-for="CapturedDate" class="form-label">@L["Poc_LabelCapturedDateUtc"]</label>
                <input asp-for="CapturedDate" type="date" class="form-control" />
                <span asp-validation-for="CapturedDate" class="text-danger small"></span>
                <div class="form-text small text-secondary">@L["Poc_DateUtcHelp"]</div>
            </div>
            <div>
                <label asp-for="PlateText" class="form-label">@L["Poc_LabelPlateText"]</label>
                <input asp-for="PlateText" class="form-control" maxlength="16" placeholder="@L["Poc_PlaceholderPlateExample"]" autocomplete="off" />
                <span asp-validation-for="PlateText" class="text-danger small"></span>
            </div>
        </div>
        <div class="grid grid-2 mb-3">
            <div>
                <label asp-for="PlateType" class="form-label">@L["Poc_LabelPlateTypeOption"]</label>
                <select asp-for="PlateType" class="form-select">
                    <option value="Private">@L["PlateType_Private"]</option>
                    <option value="Commercial">@L["PlateType_Commercial"]</option>
                    <option value="Government">@L["PlateType_Government"]</option>
                    <option value="Transport">@L["PlateType_Transport"]</option>
                    <option value="Taxi">@L["PlateType_Taxi"]</option>
                </select>
            </div>
            <div>
                <label asp-for="Country" class="form-label">@L["Poc_LabelCountryOption"]</label>
                <select asp-for="Country" class="form-select">
                    <option value="Qatar">@L["Country_Qatar"]</option>
                    <option value="UAE">@L["Country_UAE"]</option>
                    <option value="KSA">@L["Country_Ksa"]</option>
                    <option value="Oman">@L["Country_Oman"]</option>
                </select>
            </div>
        </div>

        <div class="mb-3 poc-save-path-row glass p-3 rounded-3 border border-secondary border-opacity-25">
            <div class="fw-semibold small mb-2 text-secondary">@L["Poc_SavePathSectionTitle"]</div>
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label mb-1" for="savePathNameInput">@L["Poc_LabelPathName"]</label>
                    <input type="text" id="savePathNameInput" name="savePathName" form="pocSavePathForm" class="form-control form-control-sm" maxlength="120" placeholder="@L["Poc_PlaceholderPathName"]" autocomplete="off" />
                </div>
                <div class="col-md-4">
                    <button type="submit" form="pocSavePathForm" class="btn btn-outline-warning btn-sm w-100" id="pocSavePathSubmit">
                        <i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i>@L["Poc_SavePathButton"]
                    </button>
                </div>
            </div>
        </div>

        <div class="mb-4 d-flex flex-wrap gap-3">
            <label class="form-check">
                <input asp-for="AlertOnLastSite" class="form-check-input" />
                <span class="form-check-label">@L["Poc_AlertLastOnlyLabel"]</span>
            </label>
            <label class="form-check">
                <input asp-for="SpeedViolationOnLastSite" class="form-check-input" />
                <span class="form-check-label">@L["Poc_SpeedViolationLastLabel"]</span>
            </label>
        </div>

        <button type="submit" class="btn btn-accent" id="pocSubmitBtn">
            <i class="fa-solid fa-plus me-2" aria-hidden="true"></i>@L["Poc_InsertAlongPathButton"]
        </button>
        <a class="btn btn-ghost ms-2" asp-controller="Search" asp-action="Index" asp-route-window="24h">@L["Poc_OpenSearch24h"]</a>
    </form>

    <form asp-action="SavePath" method="post" id="pocSavePathForm" class="d-none" aria-hidden="true">
        @Html.AntiForgeryToken()
        <div id="pocSavePathFields"></div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const initialPathIds = @Html.Raw(initialPathJson);
            const pocI18n = @Html.Raw(pocI18nJson);
            const pick = document.getElementById("pocPickDevice");
            const addBtn = document.getElementById("pocAddDevice");
            const clearBtn = document.getElementById("pocClearPath");
            const listEl = document.getElementById("pocPathList");
            const fieldsEl = document.getElementById("pocPathFields");
            const saveFieldsEl = document.getElementById("pocSavePathFields");
            const emptyEl = document.getElementById("pocPathEmpty");
            const form = document.getElementById("pocRouteForm");
            const saveForm = document.getElementById("pocSavePathForm");
            const loadSelect = document.getElementById("pocSavedRouteSelect");
            const loadBtn = document.getElementById("pocLoadSavedBtn");

            const path = Array.isArray(initialPathIds)
                ? initialPathIds.map(function (x) { return parseInt(x, 10); }).filter(function (id) { return id > 0; })
                : [];

            function escapeHtml(s) {
                return String(s)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;");
            }

            function deviceLabelFallback(id) {
                return (pocI18n.deviceFmt || "").replace("{0}", String(id));
            }

            function syncToContainer(container, inputName) {
                if (!container) return;
                container.innerHTML = "";
                path.forEach(function (id) {
                    const inp = document.createElement("input");
                    inp.type = "hidden";
                    inp.name = inputName;
                    inp.value = String(id);
                    container.appendChild(inp);
                });
            }

            function syncGenerateFields() {
                syncToContainer(fieldsEl, "PathDeviceIds");
            }

            function syncSaveFields() {
                syncToContainer(saveFieldsEl, "pathDeviceIds");
            }

            function render() {
                listEl.innerHTML = "";
                path.forEach(function (id, idx) {
                    const opt = pick && pick.querySelector('option[value="' + id + '"]');
                    const label = opt ? opt.textContent : deviceLabelFallback(id);
                    const mu = escapeHtml(pocI18n.moveUp || "");
                    const md = escapeHtml(pocI18n.moveDown || "");
                    const rm = escapeHtml(pocI18n.remove || "");
                    const li = document.createElement("li");
                    li.className = "list-group-item d-flex align-items-center justify-content-between gap-2 poc-path-item";
                    li.innerHTML =
                        '<span class="small"><span class="text-secondary me-2">' + (idx + 1) + ".</span>" + escapeHtml(label) + "</span>" +
                        '<span class="btn-group btn-group-sm">' +
                        '<button type="button" class="btn btn-outline-secondary poc-up" data-i="' + idx + '" title="' + mu + '">↑</button>' +
                        '<button type="button" class="btn btn-outline-secondary poc-down" data-i="' + idx + '" title="' + md + '">↓</button>' +
                        '<button type="button" class="btn btn-outline-danger poc-remove" data-i="' + idx + '" title="' + rm + '">×</button>' +
                        "</span>";
                    listEl.appendChild(li);
                });
                emptyEl.classList.toggle("d-none", path.length > 0);
                syncGenerateFields();
                syncSaveFields();
            }

            function addSelected() {
                const v = pick && pick.value;
                if (!v) return;
                const id = parseInt(v, 10);
                if (!id) return;
                path.push(id);
                pick.value = "";
                render();
            }

            addBtn && addBtn.addEventListener("click", addSelected);
            clearBtn &&
                clearBtn.addEventListener("click", function () {
                    path.length = 0;
                    render();
                });

            loadBtn &&
                loadBtn.addEventListener("click", function () {
                    if (!loadSelect || !loadSelect.value) return;
                    const opt = loadSelect.options[loadSelect.selectedIndex];
                    const csv = opt.getAttribute("data-device-ids") || "";
                    path.length = 0;
                    csv.split(",").forEach(function (s) {
                        const id = parseInt(s.trim(), 10);
                        if (id > 0) path.push(id);
                    });
                    render();
                });

            listEl.addEventListener("click", function (e) {
                const rm = e.target.closest(".poc-remove");
                const up = e.target.closest(".poc-up");
                const dn = e.target.closest(".poc-down");
                if (rm) {
                    const i = parseInt(rm.getAttribute("data-i"), 10);
                    path.splice(i, 1);
                    render();
                } else if (up) {
                    const i = parseInt(up.getAttribute("data-i"), 10);
                    if (i > 0) {
                        const t = path[i - 1];
                        path[i - 1] = path[i];
                        path[i] = t;
                        render();
                    }
                } else if (dn) {
                    const i = parseInt(dn.getAttribute("data-i"), 10);
                    if (i < path.length - 1) {
                        const t = path[i + 1];
                        path[i + 1] = path[i];
                        path[i] = t;
                        render();
                    }
                }
            });

            form &&
                form.addEventListener("submit", function () {
                    syncGenerateFields();
                });

            saveForm &&
                saveForm.addEventListener("submit", function () {
                    syncSaveFields();
                });

            render();
        })();
    </script>
}
