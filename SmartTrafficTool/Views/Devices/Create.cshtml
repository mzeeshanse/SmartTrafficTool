@model SmartTrafficTool.Models.Device
@{
    ViewData["Title"] = "Add Device";
}

<div class="card">
    <h3>Add Device</h3>
    <form asp-action="Create" method="post" class="mt-3">
        <div class="mb-3">
            <label class="form-label">Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Type</label>
            <select asp-for="Type" class="form-select">
                @foreach (var type in (string[])ViewBag.DeviceTypes)
                {
                    <option value="@type">@type</option>
                }
            </select>
            <span asp-validation-for="Type" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Status</label>
            <select asp-for="Status" class="form-select">
                @foreach (var status in (string[])ViewBag.StatusOptions)
                {
                    <option value="@status">@status</option>
                }
            </select>
            <span asp-validation-for="Status" class="text-warning"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Location</label>
            <select asp-for="LocationDescription" class="form-select">
                @foreach (var location in (string[])ViewBag.LocationOptions)
                {
                    <option value="@location">@location</option>
                }
            </select>
        </div>
        <div class="grid grid-2">
            <div>
                <label class="form-label">Latitude</label>
                <input asp-for="Latitude" class="form-control" />
            </div>
            <div>
                <label class="form-label">Longitude</label>
                <input asp-for="Longitude" class="form-control" />
            </div>
        </div>
        <div class="mb-3 mt-3">
            <label class="form-label">Stream URL</label>
            <input asp-for="StreamUrl" class="form-control" />
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-accent" type="submit">Save</button>
            <a class="btn btn-ghost" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
